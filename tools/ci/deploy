#!/bin/bash
set -euo pipefail

SERVER_DIR="${FX_SERVER_DIR:?Set FX_SERVER_DIR to your cfx-server directory}"
RESOURCE_DIR="${FX_RESOURCE_DIR:?Set FX_RESOURCE_DIR to your resource directory}"
PROJECT_DIR="$(cd "$(dirname "$0")/../.." && pwd)"
BUILD_DIR="$PROJECT_DIR/build"
OUT_DIR="$BUILD_DIR/bin/Release"

cd "$PROJECT_DIR"

rm -rf "$BUILD_DIR"

python3 tools/native_db.py
python3 tools/embed_sdk.py

premake5 gmake2
make -C "$BUILD_DIR" -f citizen-scripting-cpp.make config=release \
        CC="zig cc -target x86_64-linux-musl" \
        CXX="zig c++ -target x86_64-linux-musl" \
        -j"$(nproc)"

cp "$OUT_DIR/libcitizen-scripting-cpp.so" "$SERVER_DIR/"

rm -rf "$RESOURCE_DIR"
mkdir -p "$RESOURCE_DIR"
cp "$PROJECT_DIR/tools/example/server.cpp" "$RESOURCE_DIR/server.cpp"
cp "$PROJECT_DIR/tools/example/fxmanifest.lua" "$RESOURCE_DIR/fxmanifest.lua"

echo "Done. Runtime -> $SERVER_DIR, resource -> $RESOURCE_DIR"
