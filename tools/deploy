#!/bin/bash
set -euo pipefail

SERVER_DIR="${FX_SERVER_DIR:?Set FX_SERVER_DIR to your cfx-server directory}"
RESOURCE_DIR="${FX_RESOURCE_DIR:?Set FX_RESOURCE_DIR to your resource directory}"
PROJECT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
BUILD_DIR="$PROJECT_DIR/build"
OUT_DIR="$BUILD_DIR/bin/Release"
MUSL_TARGET="x86_64-unknown-linux-musl"

usage() {
    echo "Usage: $0 [--type <native|wasm>]" >&2
    echo "  No flags = dual mode (native + wasm)" >&2
    echo "  --type native = native only" >&2
    echo "  --type wasm = wasm only" >&2
    exit 1
}

BUILD_TYPE=""
while [[ $# -gt 0 ]]; do
    case "$1" in
        --type=*) BUILD_TYPE="${1#--type=}"; shift ;;
        --type) BUILD_TYPE="${2:?--type requires a value}"; shift 2 ;;
        *) echo "Error: unknown option '$1'" >&2; usage ;;
    esac
done

if [[ -n "$BUILD_TYPE" && "$BUILD_TYPE" != "native" && "$BUILD_TYPE" != "wasm" ]]; then
    echo "Error: unknown build type '$BUILD_TYPE' (expected 'native' or 'wasm')" >&2
    exit 1
fi

bootstrap() {
    local lib="$PROJECT_DIR/vendor/wasmtime/target/$MUSL_TARGET/release/libwasmtime.a"
    [[ -f "$lib" ]] && return
    git -C "$PROJECT_DIR" submodule update --init --depth=1 vendor/wasmtime
    rustup target add "$MUSL_TARGET"
    cargo build --release -p wasmtime-c-api \
        --target "$MUSL_TARGET" \
        --manifest-path "$PROJECT_DIR/vendor/wasmtime/Cargo.toml"
}

build_runtime() {
    rm -rf "$BUILD_DIR"
    python3 tools/code-gen/build.py
    local premake_args=""
    if [[ "$BUILD_TYPE" == "native" ]]; then
        premake_args="--native"
    elif [[ "$BUILD_TYPE" == "wasm" ]]; then
        premake_args="--wasm"
    fi
    premake5 gmake2 $premake_args
    echo "Building runtime..."
    make -C "$BUILD_DIR" config=release \
        CC="zig cc -target x86_64-linux-musl" \
        CXX="zig c++ -target x86_64-linux-musl" \
        -j"$(nproc)"
}

build_wasm_resource() {
    echo "Compiling example resource to WASM..."
    clang++ --target=wasm32-wasip1 -O2 -std=c++23 \
        --sysroot=/usr/share/wasi-sysroot \
        -fno-exceptions \
        -I"$PROJECT_DIR" \
        -Wl,--export-memory \
        "$PROJECT_DIR/tools/example/server.cpp" \
        -o "$OUT_DIR/server.wasm"
}

build_native_resource() {
    echo "Compiling example resource to native..."
    zig c++ -target x86_64-linux-musl -std=c++23 -O2 -shared -fPIC -fvisibility=hidden \
        -I"$PROJECT_DIR" \
        "$PROJECT_DIR/tools/example/server.cpp" \
        -o "$OUT_DIR/server.so"
}

deploy() {
    cp "$OUT_DIR/libcitizen-scripting-cpp.so" "$SERVER_DIR/"
    rm -rf "$RESOURCE_DIR"
    mkdir -p "$RESOURCE_DIR"
    cp "$PROJECT_DIR/tools/example/server.cpp" "$RESOURCE_DIR/server.cpp"
    if [[ "$BUILD_TYPE" == "wasm" ]]; then
        cp "$OUT_DIR/server.wasm" "$RESOURCE_DIR/server.wasm"
        sed 's/server\.so/server.wasm/' "$PROJECT_DIR/tools/example/fxmanifest.lua" > "$RESOURCE_DIR/fxmanifest.lua"
    elif [[ "$BUILD_TYPE" == "native" ]]; then
        cp "$OUT_DIR/server.so" "$RESOURCE_DIR/server.so"
        cp "$PROJECT_DIR/tools/example/fxmanifest.lua" "$RESOURCE_DIR/fxmanifest.lua"
    else
        # Dual: deploy both
        cp "$OUT_DIR/server.so" "$RESOURCE_DIR/server.so"
        cp "$PROJECT_DIR/tools/example/fxmanifest.lua" "$RESOURCE_DIR/fxmanifest.lua"
    fi
}

cd "$PROJECT_DIR"

if [[ "$BUILD_TYPE" != "native" ]]; then
    bootstrap
fi

build_runtime

RESOURCE_TYPE="$BUILD_TYPE"
if [[ -z "$RESOURCE_TYPE" ]]; then
    echo ""
    echo "Compile example resource as:"
    echo "  1) native"
    echo "  2) wasm"
    read -rp "Select [1/2]: " choice
    case "$choice" in
        1) RESOURCE_TYPE="native" ;;
        2) RESOURCE_TYPE="wasm" ;;
        *) echo "Invalid choice"; exit 1 ;;
    esac
fi

if [[ "$RESOURCE_TYPE" == "wasm" ]]; then
    build_wasm_resource
else
    build_native_resource
fi

BUILD_TYPE="$RESOURCE_TYPE"
deploy

echo "Done. Runtime -> $SERVER_DIR, resource -> $RESOURCE_DIR"
